{
  "name": "coderpad-prysm",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "eslint .",
    "storybook": "pnpm --filter @prysm/design-system storybook",
    "prompt-builder": "pnpm --filter @prysm/prompt-builder dev",
    "build:storybook": "pnpm --filter @prysm/design-system build-storybook",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.4.2",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "turbo": "^2.5.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2"
  }
}
